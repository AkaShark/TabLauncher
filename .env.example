# Copy to .env.local and fill in your OAuth credentials.
#
# TickTick (intl) developers register at https://developer.ticktick.com
# dida365  (CN)   developers register at https://developer.dida365.com
# Both share the same backend; pick the host that matches where your app
# is registered.
#
# Default region: dida365 (CN). To use ticktick.com instead, uncomment the
# two HOST lines below.

VITE_TICKTICK_CLIENT_ID=
VITE_TICKTICK_CLIENT_SECRET=

# VITE_TICKTICK_OAUTH_HOST=ticktick.com
# VITE_TICKTICK_API_HOST=api.ticktick.com
